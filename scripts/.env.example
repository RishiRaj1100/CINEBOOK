# scripts/.env.example
# Copy this to .env.local in the project root and fill in your values.
# These are used by the Node.js scripts in the scripts/ directory.

# Supabase Postgres (Direct/Pooler connection)
DB_HOST=aws-0-<region>.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.<your-project-ref>
DB_PASSWORD=<your-supabase-db-password>

# TMDB API
TMDB_API_KEY=<your-tmdb-api-key>
