# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─── Dependencies ────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Build Outputs ───────────────────────────────────────────────────────────
/.next/
/out/
/build
/coverage

# ─── Environment & Secrets ───────────────────────────────────────────────────
# Never commit credentials — use .env.example as a template
.env
.env.local
.env.*.local
.env.development
.env.production
*.pem

# ─── Logs & Debug ────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── OS & Editor ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ─── AI Agent Files ──────────────────────────────────────────────────────────
# These are internal AI coding assistant config files — not part of the project
AGENTS.md
CLAUDE.md
.agents/
.gemini/
.cursor/

# ─── TypeScript ──────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Vercel ──────────────────────────────────────────────────────────────────
.vercel
